# Local Development Environment Variables Template
# DO NOT add real credentials here!

# Local Database Configuration
DB_URL=jdbc:mysql://localhost:3306/jankalyan_dev?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=password

# Local JWT Authentication (Keep these same as application default if unchanged)
JWT_SECRET=your-local-256-bit-secure-secret-key-that-is-at-least-32-characters-long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_DAYS=7

# Local Cloudinary Integration (Mock values for local dev)
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo
CLOUDINARY_API_SECRET=demo
