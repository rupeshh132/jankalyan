# General / Production Environment Variables Template
# DO NOT add real credentials here!

# Database Configuration
DB_URL=jdbc:mysql://your-prod-db-host:3306/db_name
DB_USERNAME=your-prod-db-username
DB_PASSWORD=your-secure-db-password

# JWT Authentication
JWT_SECRET=your-256-bit-secure-secret-key-that-is-at-least-32-characters-long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_DAYS=7

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
